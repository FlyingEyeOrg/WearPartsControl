<UserControl x:Class="WearPartsControl.UserControls.UserTabControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WearPartsControl.UserControls"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <UserControl.Resources>
        <SolidColorBrush x:Key="TabHoverBrush"
                         Color="#FFB7D3EA" />
        <SolidColorBrush x:Key="TabTextBrush"
                         Color="#FF1F2D3D" />

        <Style x:Key="TabItemButtonStyle"
               TargetType="ToggleButton">
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Padding"
                    Value="0" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Stretch" />
            <Setter Property="VerticalContentAlignment"
                    Value="Stretch" />
            <Setter Property="HorizontalAlignment"
                    Value="Stretch" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Foreground"
                    Value="{StaticResource TabTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver"
                                               Value="True" />
                                    <Condition Property="IsChecked"
                                               Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="RootBorder"
                                        Property="Background"
                                        Value="{StaticResource TabHoverBrush}" />
                            </MultiTrigger>
                            <Trigger Property="IsChecked"
                                     Value="True">
                                <Setter TargetName="RootBorder"
                                        Property="Background"
                                        Value="{DynamicResource PrimaryBrush}" />
                                <Setter Property="Foreground"
                                        Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ScrollViewer Width="240"
                      VerticalScrollBarVisibility="Auto">
            <!--
                                说明：
                                - 使用 AlternationCount + AlternationIndex 的技巧来在 DataTemplate 内获取当前项的索引。
                                    将 AlternationCount 设为一个足够大的值（如 Int32.MaxValue）使 AlternationIndex 在项数远小于该值时
                                    等同于序号（index），从而可以在模板中把索引绑定到控件的 Tag 上，避免运行时遍历视觉树。
                                - 模板内的按钮命名为 TabButton，代码通过 ContentPresenter.ContentTemplate.FindName("TabButton", presenter)
                                    精确获取对应按钮实例，代替通用的视觉树递归。
                        -->
            <ItemsControl x:Name="TabItemsControl"
                          AlternationCount="{x:Static sys:Int32.MaxValue}"
                          ItemsSource="{Binding Headers, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=local:UserTabControl}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- ToggleButton: Tag 绑定为容器的 AlternationIndex（即项索引），
                                Name 为 TabButton 以便代码直接从 ContentPresenter.ContentTemplate.FindName 获取实例 -->
                        <ToggleButton x:Name="TabButton"
                                      Checked="TabItemButton_Checked"
                                      Tag="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=(ItemsControl.AlternationIndex)}"
                                      Unchecked="TabItemButton_Unchecked"
                                      Style="{StaticResource TabItemButtonStyle}">
                            <Border Padding="12,10">
                                <TextBlock FontSize="16"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Text="{Binding .}" />
                            </Border>
                        </ToggleButton>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid Grid.Column="1"
              Width="1"
              Background="{DynamicResource PrimaryBrush}" />

        <Border Grid.Column="2"
                MinWidth="0"
                MinHeight="0"
                Background="AliceBlue">
            <ContentControl MinWidth="0"
                            MinHeight="0"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Content="{Binding SelectedContent, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=local:UserTabControl}}" />
        </Border>
    </Grid>
</UserControl>