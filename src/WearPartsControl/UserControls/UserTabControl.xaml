<UserControl x:Class="WearPartsControl.UserControls.UserTabControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WearPartsControl.UserControls"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <UserControl.Resources>
            <ResourceDictionary>
                <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WearPartsControl;component/Resources/ShellContentStyles.xaml" />
                </ResourceDictionary.MergedDictionaries>
                <SolidColorBrush x:Key="TabHoverBrush"
                     Color="#FFE7F1F7" />
                <SolidColorBrush x:Key="TabTextBrush"
                         Color="#FF1F2D3D" />
                <SolidColorBrush x:Key="TabPanelBackgroundBrush"
                     Color="#FFF8FBFD" />
                <SolidColorBrush x:Key="TabPanelBorderBrush"
                     Color="#FFDFE9F1" />

                <Style x:Key="TabItemButtonStyle"
                   TargetType="ToggleButton">
                <Setter Property="Background"
                    Value="Transparent" />
                <Setter Property="BorderThickness"
                    Value="0" />
                <Setter Property="Padding"
                    Value="0" />
                <Setter Property="HorizontalContentAlignment"
                    Value="Stretch" />
                <Setter Property="VerticalContentAlignment"
                    Value="Stretch" />
                <Setter Property="HorizontalAlignment"
                    Value="Stretch" />
                <Setter Property="Cursor"
                    Value="Hand" />
                <Setter Property="Foreground"
                    Value="{StaticResource TabTextBrush}" />
                <Setter Property="Template">
                    <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="RootBorder"
                        Background="{TemplateBinding Background}"
                        CornerRadius="14">
                        <ContentPresenter HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                            <Condition Property="IsMouseOver"
                                   Value="True" />
                            <Condition Property="IsChecked"
                                   Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="RootBorder"
                                Property="Background"
                                Value="{StaticResource TabHoverBrush}" />
                        </MultiTrigger>
                        <Trigger Property="IsChecked"
                             Value="True">
                            <Setter TargetName="RootBorder"
                                Property="Background"
                                Value="{DynamicResource PrimaryBrush}" />
                            <Setter Property="Foreground"
                                Value="White" />
                        </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                    </Setter.Value>
                </Setter>
                </Style>
            </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Width="220"
            Margin="0 0 12 0"
                Background="{StaticResource TabPanelBackgroundBrush}"
                BorderBrush="{StaticResource TabPanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="18">
            <ScrollViewer Padding="12"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="TabItemsControl"
                          AlternationCount="{x:Static sys:Int32.MaxValue}"
                          ItemsSource="{Binding Headers, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=local:UserTabControl}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ToggleButton x:Name="TabButton"
                                      Checked="TabItemButton_Checked"
                                      Tag="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=(ItemsControl.AlternationIndex)}"
                                      Unchecked="TabItemButton_Unchecked"
                                      Margin="0 0 0 8"
                                      Style="{StaticResource TabItemButtonStyle}">
                            <Border Padding="14,12">
                                <TextBlock FontSize="16"
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Text="{Binding .}" />
                            </Border>
                        </ToggleButton>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            </ScrollViewer>
        </Border>

        <Border Grid.Column="1"
                MinWidth="0"
                MinHeight="0"
                Padding="12"
                Background="#FFF8FBFD"
                BorderBrush="#DCE7EF"
                BorderThickness="1"
                CornerRadius="18">
            <ContentControl MinWidth="0"
                            MinHeight="0"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Content="{Binding SelectedContent, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=local:UserTabControl}}" />
        </Border>
    </Grid>
</UserControl>