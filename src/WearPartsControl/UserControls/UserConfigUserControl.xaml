<UserControl x:Class="WearPartsControl.UserControls.UserConfigUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d"
             d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Background="#FF365082"
                    Padding="0 8">
                <TextBlock HorizontalAlignment="Center"
                           FontWeight="Bold"
                           FontSize="16"
                           Foreground="White">用户配置</TextBlock>
            </Border>

            <TextBlock Margin="8 16 8 0"
                       FontWeight="SemiBold"
                       Foreground="#FF365082">通知配置</TextBlock>

            <Grid Margin="8 8 8 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <TextBlock HorizontalAlignment="Left"
                           VerticalAlignment="Center">ME 负责人工号：</TextBlock>
                <TextBox Grid.Column="1"
                         Style="{StaticResource TextBoxExtend}"
                         Text="{Binding MeResponsibleWorkId, UpdateSourceTrigger=PropertyChanged}"
                         hc:InfoElement.Placeholder="请输入 ME 负责人工号" />
            </Grid>
            <Grid Margin="8 8 8 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <TextBlock HorizontalAlignment="Left"
                           VerticalAlignment="Center">PRD 负责人工号：</TextBlock>
                <TextBox Grid.Column="1"
                         Style="{StaticResource TextBoxExtend}"
                         Text="{Binding PrdResponsibleWorkId, UpdateSourceTrigger=PropertyChanged}"
                         hc:InfoElement.Placeholder="请输入 PRD 负责人工号" />
            </Grid>
            <Grid Margin="8 8 8 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <TextBlock HorizontalAlignment="Left"
                           VerticalAlignment="Center">启用 COM 通知：</TextBlock>
                <CheckBox Grid.Column="1"
                          VerticalAlignment="Center"
                          IsEnabled="False"
                          IsChecked="{Binding ComNotificationEnabled, Mode=OneWay}" />
            </Grid>
            <Grid Margin="8 8 8 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <TextBlock HorizontalAlignment="Left"
                           VerticalAlignment="Center">PushUrl：</TextBlock>
                <TextBox Grid.Column="1"
                         IsReadOnly="True"
                         Style="{StaticResource TextBoxExtend}"
                         Text="{Binding ComPushUrl, Mode=OneWay}" />
            </Grid>
            <Grid Margin="8 8 8 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <TextBlock HorizontalAlignment="Left"
                           VerticalAlignment="Center">DeIpaasKeyAuth：</TextBlock>
                <TextBox Grid.Column="1"
                         IsReadOnly="True"
                         Style="{StaticResource TextBoxExtend}"
                         Text="{Binding ComDeIpaasKeyAuth, Mode=OneWay}" />
            </Grid>
            <Grid Margin="8 8 8 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <TextBlock HorizontalAlignment="Left"
                           VerticalAlignment="Center">AgentId：</TextBlock>
                <TextBox Grid.Column="1"
                         IsReadOnly="True"
                         Style="{StaticResource TextBoxExtend}"
                         Text="{Binding ComAgentId, Mode=OneWay}" />
            </Grid>
            <Grid Margin="8 8 8 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <TextBlock HorizontalAlignment="Left"
                           VerticalAlignment="Center">GroupTemplateId：</TextBlock>
                <TextBox Grid.Column="1"
                         IsReadOnly="True"
                         Style="{StaticResource TextBoxExtend}"
                         Text="{Binding ComGroupTemplateId, Mode=OneWay}" />
            </Grid>
            <Grid Margin="8 8 8 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <TextBlock HorizontalAlignment="Left"
                           VerticalAlignment="Center">WorkTemplateId：</TextBlock>
                <TextBox Grid.Column="1"
                         IsReadOnly="True"
                         Style="{StaticResource TextBoxExtend}"
                         Text="{Binding ComWorkTemplateId, Mode=OneWay}" />
            </Grid>
            <Grid Margin="8 8 8 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <TextBlock HorizontalAlignment="Left"
                           VerticalAlignment="Center">UserType：</TextBlock>
                <TextBox Grid.Column="1"
                         IsReadOnly="True"
                         Style="{StaticResource TextBoxExtend}"
                         Text="{Binding ComUserType, Mode=OneWay}" />
            </Grid>
            <Grid Margin="8 8 8 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <TextBlock HorizontalAlignment="Left"
                           VerticalAlignment="Center">ComAccessToken：</TextBlock>
                <TextBox Grid.Column="1"
                         Style="{StaticResource TextBoxExtend}"
                         Text="{Binding ComAccessToken, UpdateSourceTrigger=PropertyChanged}"
                         hc:InfoElement.Placeholder="请输入 Com 群访问令牌" />
            </Grid>
            <Grid Margin="8 8 8 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <TextBlock HorizontalAlignment="Left"
                           VerticalAlignment="Center">ComSecret：</TextBlock>
                <TextBox Grid.Column="1"
                         Style="{StaticResource TextBoxExtend}"
                         Text="{Binding ComSecret, UpdateSourceTrigger=PropertyChanged}"
                         hc:InfoElement.Placeholder="请输入 Com 群 Secret" />
            </Grid>

            <TextBlock Margin="8 16 8 0"
                       FontWeight="SemiBold"
                       Foreground="#FF365082">垫片校验配置</TextBlock>

            <Grid Margin="8 8 8 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <TextBlock HorizontalAlignment="Left"
                           VerticalAlignment="Center">启用垫片校验：</TextBlock>
                <CheckBox Grid.Column="1"
                          VerticalAlignment="Center"
                          IsChecked="{Binding SpacerValidationEnabled}" />
            </Grid>
            <Grid Margin="8 8 8 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <TextBlock HorizontalAlignment="Left"
                           VerticalAlignment="Center">校验接口地址：</TextBlock>
                <TextBox Grid.Column="1"
                         Style="{StaticResource TextBoxExtend}"
                         Text="{Binding SpacerValidationUrl, UpdateSourceTrigger=PropertyChanged}"
                         hc:InfoElement.Placeholder="请输入垫片校验接口地址" />
            </Grid>
            <Grid Margin="8 8 8 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <TextBlock HorizontalAlignment="Left"
                           VerticalAlignment="Center">请求超时（毫秒）：</TextBlock>
                <TextBox Grid.Column="1"
                         Style="{StaticResource TextBoxExtend}"
                         Text="{Binding SpacerValidationTimeoutMilliseconds, UpdateSourceTrigger=PropertyChanged}"
                         hc:InfoElement.Placeholder="请输入超时时间，默认 5000" />
            </Grid>
            <Grid Margin="8 8 8 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <TextBlock HorizontalAlignment="Left"
                           VerticalAlignment="Center">忽略证书错误：</TextBlock>
                <CheckBox Grid.Column="1"
                          VerticalAlignment="Center"
                          IsChecked="{Binding SpacerValidationIgnoreServerCertificateErrors}" />
            </Grid>
            <Grid Margin="8 8 8 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <TextBlock HorizontalAlignment="Left"
                           VerticalAlignment="Center">条码分隔符：</TextBlock>
                <TextBox Grid.Column="1"
                         Style="{StaticResource TextBoxExtend}"
                         Text="{Binding SpacerValidationCodeSeparator, UpdateSourceTrigger=PropertyChanged}"
                         hc:InfoElement.Placeholder="请输入条码分隔符，默认 /" />
            </Grid>
            <Grid Margin="8 8 8 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <TextBlock HorizontalAlignment="Left"
                           VerticalAlignment="Center">条码段数：</TextBlock>
                <TextBox Grid.Column="1"
                         Style="{StaticResource TextBoxExtend}"
                         Text="{Binding SpacerValidationExpectedSegmentCount, UpdateSourceTrigger=PropertyChanged}"
                         hc:InfoElement.Placeholder="请输入条码段数，默认 8" />
            </Grid>

            <Grid Margin="8 16 8 8">
                <Button Width="80"
                        Style="{StaticResource ButtonPrimary}"
                        Command="{Binding SaveCommand}">保存信息</Button>
                <Button Width="120"
                        HorizontalAlignment="Right"
                        Command="{Binding TestComNotificationCommand}">测试 COM 通知</Button>
            </Grid>
            <TextBlock Margin="8 0 8 8"
                       Foreground="#FF365082"
                       TextWrapping="Wrap"
                       Text="{Binding StatusMessage}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
