<UserControl x:Class="WearPartsControl.UserControls.UserConfigUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WearPartsControl.UserControls"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <StackPanel>
        <Border Background="#FF365082"
                Padding="0 4">
            <TextBlock HorizontalAlignment="Center"
                       FontWeight="Bold"
                       FontSize="16"
                       Foreground="White">用户配置</TextBlock>
        </Border>
        <Grid Margin="8 8 8 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <TextBlock HorizontalAlignment="Left"
                       VerticalAlignment="Center">ME 负责人工号：</TextBlock>
            <TextBox Style="{StaticResource TextBoxExtend}"
                     hc:InfoElement.Placeholder="请输入 ME 负责人工号"
                     Grid.Column="1"></TextBox>
        </Grid>
        <Grid Margin="8 8 8 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <TextBlock HorizontalAlignment="Left"
                       VerticalAlignment="Center">PRD 负责人工号：</TextBlock>
            <TextBox Style="{StaticResource TextBoxExtend}"
                     hc:InfoElement.Placeholder="请输入 PRD 负责人工号"
                     Grid.Column="1"></TextBox>
        </Grid>
        <Grid Margin="8 8 8 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <TextBlock HorizontalAlignment="Left"
                       VerticalAlignment="Center">ComAccessToken：</TextBlock>
            <TextBox Style="{StaticResource TextBoxExtend}"
                     hc:InfoElement.Placeholder="请输入 Com 群访问令牌"
                     Grid.Column="1"></TextBox>
        </Grid>
        <Grid Margin="8 8 8 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <TextBlock HorizontalAlignment="Left"
                       VerticalAlignment="Center">ComSecret：</TextBlock>
            <TextBox Style="{StaticResource TextBoxExtend}"
                     hc:InfoElement.Placeholder="请输入 Com 群 Secret"
                     Grid.Column="1"></TextBox>
        </Grid>
        <Grid Margin="8 16 8 8">
            <Button Width="80"
                    Style="{StaticResource ButtonPrimary}">保存信息</Button>
            <Button Width="120"
                    HorizontalAlignment="Right">测试 COM 通知</Button>
        </Grid>
    </StackPanel>
</UserControl>
