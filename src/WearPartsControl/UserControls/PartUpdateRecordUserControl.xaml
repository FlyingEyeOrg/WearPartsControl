<UserControl x:Class="WearPartsControl.UserControls.PartUpdateRecordUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WearPartsControl.UserControls"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel>
            <Border Background="#FF365082"
                    Padding="0 4">
                <TextBlock HorizontalAlignment="Center"
                           FontWeight="Bold"
                           FontSize="16"
                           Foreground="White">易损件更换记录</TextBlock>
            </Border>
            <StackPanel Orientation="Horizontal"
                        Margin="8 8 8 0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="200" />
                    </Grid.ColumnDefinitions>
                    <TextBlock HorizontalAlignment="Left"
                               VerticalAlignment="Center">易损件：</TextBlock>
                    <ComboBox Style="{StaticResource ComboBoxExtend}"
                              hc:InfoElement.Placeholder="请选择易损件"
                              Grid.Column="1"></ComboBox>
                </Grid>
                <Button Margin="8 0 0 0"
                        Width="80"
                        Style="{StaticResource ButtonPrimary}"
                        hc:IconElement.Geometry="{StaticResource SearchGeometry}">查询</Button>
                <Button Margin="8 0 0 0"
                        Width="80"
                        Style="{StaticResource ButtonPrimary}"
                        hc:IconElement.Geometry="{StaticResource SaveGeometry}">导出</Button>
            </StackPanel>
        </StackPanel>
        <DataGrid Grid.Row="1"
                  Margin="0 8 0 0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="名称"
                                    Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="旧编码"
                                    Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="新编码"
                                    Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="当前寿命"
                                    Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="预警寿命"
                                    Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="停机寿命"
                                    Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="更换时间"
                                    Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="操作员"
                                    Width="*"></DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Margin="8 8 8 8"
                    Grid.Row="2"
                    Orientation="Horizontal">
            <Button Style="{StaticResource ButtonIconCircular}"
                    hc:IconElement.Geometry="{StaticResource LeftGeometry}"></Button>
            <TextBox Margin="8 0 0 0"
                     HorizontalContentAlignment="Center"
                     Width="40">1</TextBox>
            <Button Margin="8 0 0 0"
                    Style="{StaticResource ButtonIconCircular}"
                    hc:IconElement.Geometry="{StaticResource RightGeometry}"></Button>
            <TextBlock Margin="8 0 0 0"
                       VerticalAlignment="Center">第</TextBlock>
            <TextBox Margin="8 0 0 0"
                     HorizontalContentAlignment="Center"
                     Width="40">1</TextBox>
            <TextBlock Margin="8 0 0 0"
                       VerticalAlignment="Center">页</TextBlock>
            <Button Margin="8 0 0 0"
                    Style="{StaticResource ButtonIconCircular}"
                    hc:IconElement.Geometry="{StaticResource SearchGeometry}"></Button>
        </StackPanel>
    </Grid>
</UserControl>
