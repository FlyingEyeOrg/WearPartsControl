<UserControl x:Class="WearPartsControl.UserControls.PartUpdateRecordUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:WearPartsControl.ApplicationServices.Localization"
             xmlns:vm="clr-namespace:WearPartsControl.ViewModels"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=vm:PartUpdateRecordViewModel}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel>
            <Border Background="#FF365082"
                    Padding="0 8">
                <TextBlock HorizontalAlignment="Center"
                           FontWeight="Bold"
                           FontSize="16"
                           Foreground="White"
                           Text="{loc:Loc PartUpdateRecordControl.Title}" />
            </Border>
            <Border Margin="8 8 8 0"
                    CornerRadius="6"
                    Background="#FFF5F7FA"
                    BorderBrush="#FFD9E2F2"
                    BorderThickness="1">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource InfoBrush}"
                               Text="{Binding StatusMessage, Mode=OneWay}" />
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal">
                        <TextBlock Margin="16 0 0 0"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0}{1}">
                                    <Binding Source="{loc:Loc PartUpdateRecordControl.CurrentResourceNumberLabel}" />
                                    <Binding Path="ResourceNumber" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <Button Margin="16 0 0 0"
                                Width="80"
                                Command="{Binding RefreshCommand}"
                                Style="{StaticResource ButtonPrimary}"
                                Content="{loc:Loc PartUpdateRecordControl.RefreshButton}" />
                    </StackPanel>
                </Grid>
            </Border>
            <StackPanel Orientation="Horizontal"
                        Margin="8 8 8 0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="240" />
                    </Grid.ColumnDefinitions>
                    <TextBlock HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Text="{loc:Loc PartUpdateRecordControl.PartLabel}" />
                    <ComboBox Grid.Column="1"
                              Style="{StaticResource ComboBoxExtend}"
                              ItemsSource="{Binding Definitions}"
                              SelectedItem="{Binding SelectedDefinition, Mode=TwoWay}"
                              DisplayMemberPath="PartName"
                              hc:InfoElement.Placeholder="{loc:Loc PartUpdateRecordControl.PartPlaceholder}"></ComboBox>
                </Grid>
                <Button Margin="8 0 0 0"
                        Width="80"
                        Command="{Binding QueryCommand}"
                        Style="{StaticResource ButtonPrimary}"
                        hc:IconElement.Geometry="{StaticResource SearchGeometry}"
                        Content="{loc:Loc PartUpdateRecordControl.QueryButton}" />
                <Button Margin="8 0 0 0"
                        Width="80"
                        Command="{Binding ExportCommand}"
                        Style="{StaticResource ButtonPrimary}"
                        hc:IconElement.Geometry="{StaticResource SaveGeometry}"
                        Content="{loc:Loc PartUpdateRecordControl.ExportButton}" />
            </StackPanel>
        </StackPanel>
        <DataGrid Grid.Row="1"
                  Margin="8 8 8 0"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  ItemsSource="{Binding Records}"
                  Style="{StaticResource DataGridBaseStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{loc:Loc PartUpdateRecordControl.NameHeader}"
                                    Binding="{Binding PartName}"
                                    Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="{loc:Loc PartUpdateRecordControl.CurrentBarcodeHeader}"
                                    Binding="{Binding CurrentBarcode}"
                                    Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="{loc:Loc PartUpdateRecordControl.NewBarcodeHeader}"
                                    Binding="{Binding NewBarcode}"
                                    Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="{loc:Loc PartUpdateRecordControl.CurrentValueHeader}"
                                    Binding="{Binding CurrentValue}"
                                    Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="{loc:Loc PartUpdateRecordControl.WarningValueHeader}"
                                    Binding="{Binding WarningValue}"
                                    Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="{loc:Loc PartUpdateRecordControl.ShutdownValueHeader}"
                                    Binding="{Binding ShutdownValue}"
                                    Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="{loc:Loc PartUpdateRecordControl.ReasonHeader}"
                                    Binding="{Binding ReasonDisplayName}"
                                    Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="{loc:Loc PartUpdateRecordControl.ReplacedAtHeader}"
                                    Binding="{Binding ReplacedAt, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                                    Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="{loc:Loc PartUpdateRecordControl.OperatorUserNameHeader}"
                                    Binding="{Binding OperatorUserName}"
                                    Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="{loc:Loc PartUpdateRecordControl.OperatorWorkNumberHeader}"
                                    Binding="{Binding OperatorWorkNumber}"
                                    Width="*"></DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Margin="8 8 8 8"
                    Grid.Row="2"
                    Orientation="Horizontal">
            <TextBlock VerticalAlignment="Center"
                       Text="{loc:Loc PartUpdateRecordControl.PageSizePrefix}" />
            <ComboBox Margin="8 0 0 0"
                  Width="80"
                  ItemsSource="{Binding PageSizeOptions}"
                  SelectedItem="{Binding SelectedPageSize, Mode=TwoWay}"
                  Style="{StaticResource ComboBoxExtend}" />
            <TextBlock Margin="8 0 0 0"
                   VerticalAlignment="Center"
                   Text="{loc:Loc PartUpdateRecordControl.PageSizeSuffix}" />
            <Button Style="{StaticResource ButtonIconCircular}"
                Margin="16 0 0 0"
                    Command="{Binding PreviousPageCommand}"
                    hc:IconElement.Geometry="{StaticResource LeftGeometry}"></Button>
            <TextBox Margin="8 0 0 0"
                     HorizontalContentAlignment="Center"
                     Width="40"
                     IsReadOnly="True"
                     Text="{Binding CurrentPage, Mode=OneWay}"></TextBox>
            <Button Margin="8 0 0 0"
                    Command="{Binding NextPageCommand}"
                    Style="{StaticResource ButtonIconCircular}"
                    hc:IconElement.Geometry="{StaticResource RightGeometry}"></Button>
            <TextBlock Margin="8 0 0 0"
                       VerticalAlignment="Center"
                       Text="{loc:Loc PartUpdateRecordControl.GoToPagePrefix}" />
            <TextBox Margin="8 0 0 0"
                     HorizontalContentAlignment="Center"
                     Width="40"
                     Text="{Binding RequestedPageNumber, UpdateSourceTrigger=PropertyChanged}"></TextBox>
            <TextBlock Margin="8 0 0 0"
                       VerticalAlignment="Center"
                       Text="{loc:Loc PartUpdateRecordControl.GoToPageSuffix}" />
            <Button Margin="8 0 0 0"
                    Command="{Binding GoToPageCommand}"
                    Style="{StaticResource ButtonIconCircular}"
                    hc:IconElement.Geometry="{StaticResource SearchGeometry}"></Button>
            <TextBlock Margin="16 0 0 0"
                       VerticalAlignment="Center">
                <TextBlock.Text>
                    <MultiBinding StringFormat="{}{0}{1}{2}">
                        <Binding Source="{loc:Loc PartUpdateRecordControl.TotalPagesPrefix}" />
                        <Binding Path="TotalPages" />
                        <Binding Source="{loc:Loc PartUpdateRecordControl.TotalPagesSuffix}" />
                    </MultiBinding>
                </TextBlock.Text>
            </TextBlock>
        </StackPanel>
    </Grid>
</UserControl>
