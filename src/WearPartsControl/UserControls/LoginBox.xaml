                </Viewbox>
            </Border>
            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center"
                    Margin="12,0">
                <TextBlock FontWeight="SemiBold"
                           Foreground="#1E3550"
                       FontSize="14"
                           Text="{Binding CurrentUserWorkIdText}" />
                <TextBlock Margin="0 6 0 0"
                       FontSize="11"
                           Foreground="#61758A"
                           Text="{Binding CurrentUserAccessLevelText}" />
                <TextBlock Margin="0 4 0 0"
                       FontSize="11"
                           Foreground="#61758A"
                           Text="{Binding SoftwareVersionText}" />
            </StackPanel>

            <StackPanel Grid.Column="2"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right">
                <Button x:Name="LoginButton"
                        Style="{StaticResource ButtonPrimary}"
                        Command="{Binding OpenLoginCommand}"
                        Padding="14 6"
                        Content="{loc:Loc LoginBoxControl.LoginButton}"
                        Visibility="{Binding ShowLoginButton, Converter={StaticResource BooleanToVisibilityConverter}}"
                        MinWidth="92" />
                <Button x:Name="LogoutButton"
                        Margin="0 6 0 0"
                        Command="{Binding LogoutCommand}"
                        Padding="14 6"
                        Content="{loc:Loc LoginBoxControl.LogoutButton}"
                        Visibility="{Binding ShowLogoutButton, Converter={StaticResource BooleanToVisibilityConverter}}"
                        MinWidth="92" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
