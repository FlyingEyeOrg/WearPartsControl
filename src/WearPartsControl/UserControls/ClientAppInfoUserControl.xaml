<UserControl x:Class="WearPartsControl.UserControls.ClientAppInfoUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WearPartsControl.UserControls"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <StackPanel>
        <Border Background="#FF365082"
                Padding="0 4">
            <TextBlock HorizontalAlignment="Center"
                       FontWeight="Bold"
                       FontSize="16"
                       Foreground="White">客户端信息</TextBlock>
        </Border>
        <Grid Margin="8 8 8 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <TextBlock HorizontalAlignment="Left"
                               VerticalAlignment="Center">基地：</TextBlock>
                    <ComboBox Style="{StaticResource ComboBoxExtend}"
                              hc:InfoElement.Placeholder="请选择基地"
                              Grid.Column="1"></ComboBox>
                </Grid>
                <Grid Margin="0 8 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <TextBlock HorizontalAlignment="Left"
                               VerticalAlignment="Center">工序：</TextBlock>
                    <ComboBox Grid.Column="1"
                              Style="{StaticResource ComboBoxExtend}"
                              hc:InfoElement.Placeholder="请选择易工序"></ComboBox>
                </Grid>
                <Grid Margin="0 8 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <TextBlock HorizontalAlignment="Left"
                               VerticalAlignment="Center">PLC 类型：</TextBlock>
                    <ComboBox Style="{StaticResource ComboBoxExtend}"
                              hc:InfoElement.Placeholder="请选择 PLC 类型"
                              Grid.Column="1"></ComboBox>
                </Grid>
                <Grid Margin="0 8 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <TextBlock HorizontalAlignment="Left"
                               VerticalAlignment="Center">停机地址：</TextBlock>
                    <TextBox Style="{StaticResource TextBoxExtend}"
                             hc:InfoElement.Placeholder="请输入 PLC 的停机地址"
                             Grid.Column="1"></TextBox>
                </Grid>
            </StackPanel>
            <StackPanel Grid.Column="1"
                        Margin="8 0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <TextBlock HorizontalAlignment="Left"
                               VerticalAlignment="Center">工厂：</TextBlock>
                    <ComboBox Style="{StaticResource ComboBoxExtend}"
                              hc:InfoElement.Placeholder="请选择工厂"
                              Grid.Column="1"></ComboBox>
                </Grid>
                <Grid Margin="0 8 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <TextBlock HorizontalAlignment="Left"
                               VerticalAlignment="Center">设备资源号：</TextBlock>
                    <TextBox Style="{StaticResource TextBoxExtend}"
                             hc:InfoElement.Placeholder="请输入设备资源号"
                             Grid.Column="1"></TextBox>
                </Grid>
                <Grid Margin="0 8 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <TextBlock HorizontalAlignment="Left"
                               VerticalAlignment="Center">IP 地址：</TextBlock>
                    <TextBox Style="{StaticResource TextBoxExtend}"
                             hc:InfoElement.Placeholder="请输入 PLC 的 IP 地址"
                             Grid.Column="1"></TextBox>
                </Grid>
                <Grid Margin="0 8 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <TextBlock HorizontalAlignment="Left"
                               VerticalAlignment="Center">插槽号：</TextBlock>
                    <TextBox Style="{StaticResource TextBoxExtend}"
                             hc:InfoElement.Placeholder="西门子 PLC 插槽号"
                             Grid.Column="1"></TextBox>
                </Grid>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <TextBlock HorizontalAlignment="Left"
                               VerticalAlignment="Center">区域：</TextBlock>
                    <ComboBox Grid.Column="1"
                              Style="{StaticResource ComboBoxExtend}"
                              hc:InfoElement.Placeholder="请选择区域"></ComboBox>
                </Grid>
                <!--占位符-->
                <Grid Margin="0 8 0 0"
                      Visibility="Hidden">
                    <TextBox Grid.Column="1"></TextBox>
                </Grid>
                <Grid Margin="0 8 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <TextBlock HorizontalAlignment="Left"
                               VerticalAlignment="Center">端口：</TextBlock>
                    <TextBox Grid.Column="1"
                             Style="{StaticResource TextBoxExtend}"
                             hc:InfoElement.Placeholder="请输入 PLC 端口"></TextBox>
                </Grid>
            </StackPanel>
        </Grid>
        <Grid    Margin="8 16 8 8">
            <Button Width="80"
                    Style="{StaticResource ButtonPrimary}">保存信息</Button>
            <Button Width="100"
                    HorizontalAlignment="Right">测试 PLC 连接</Button>
        </Grid>
    </StackPanel>
</UserControl>
