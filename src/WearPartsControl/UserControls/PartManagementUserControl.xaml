<UserControl x:Class="WearPartsControl.UserControls.PartManagementUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WearPartsControl.UserControls"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel>
            <Border Background="#FF365082"
                    Padding="0 4">
                <TextBlock HorizontalAlignment="Center"
                           FontWeight="Bold"
                           FontSize="16"
                           Foreground="White">易损件管理</TextBlock>
            </Border>
            <StackPanel Orientation="Horizontal"
                        Margin="8 8 8 0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="120" />
                    </Grid.ColumnDefinitions>
                    <TextBlock HorizontalAlignment="Left"
                               VerticalAlignment="Center">易损件名称：</TextBlock>
                    <TextBox Style="{StaticResource TextBoxExtend}"
                             hc:InfoElement.Placeholder="请输入易损件名称"
                             Grid.Column="1"></TextBox>
                </Grid>
                <Button Margin="8 0 0 0"
                        Width="80"
                        Style="{StaticResource ButtonPrimary}"
                        hc:IconElement.Geometry="{StaticResource SearchGeometry}">查询</Button>
                <Button Margin="8 0 0 0"
                        Width="80"
                        Style="{StaticResource ButtonPrimary}"
                        hc:IconElement.Geometry="{StaticResource AddGeometry}">新增</Button>
                <Button Margin="8 0 0 0"
                        Width="80"
                        Style="{StaticResource ButtonPrimary}"
                        hc:IconElement.Geometry="{StaticResource DropperGeometry}">编辑</Button>
                <Button Margin="8 0 0 0"
                        Width="80"
                        Style="{StaticResource ButtonPrimary}"
                        hc:IconElement.Geometry="{StaticResource DeleteGeometry}">删除</Button>
                <Button Margin="8 0 0 0"
                        Style="{StaticResource ButtonPrimary}"
                        hc:IconElement.Geometry="{StaticResource AddGeometry}">从其他设备导入</Button>
            </StackPanel>
        </StackPanel>
        <DataGrid Grid.Row="1"
                  Margin="0 8 0 0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="名称"
                                    Width="Auto"></DataGridTextColumn>
                <DataGridTextColumn Header="寿命类型"
                                    Width="Auto"></DataGridTextColumn>
                <DataGridTextColumn Header="当前寿命地址"
                                    Width="Auto"></DataGridTextColumn>
                <DataGridTextColumn Header="当前寿命数据类型"
                                    Width="Auto"></DataGridTextColumn>
                <DataGridTextColumn Header="预警寿命地址"
                                    Width="Auto"></DataGridTextColumn>
                <DataGridTextColumn Header="预警寿命数据类型"
                                    Width="Auto"></DataGridTextColumn>
                <DataGridTextColumn Header="停机寿命地址"
                                    Width="Auto"></DataGridTextColumn>
                <DataGridTextColumn Header="停机寿命数据类型"
                                    Width="Auto"></DataGridTextColumn>
                <DataGridTextColumn Header="输入方式"
                                    Width="Auto"></DataGridTextColumn>
                <DataGridTextColumn Header="条码最小长度"
                                    Width="Auto"></DataGridTextColumn>
                <DataGridTextColumn Header="条码最大长度"
                                    Width="Auto"></DataGridTextColumn>
                <DataGridTextColumn Header="附加清零地址"
                                    Width="Auto"></DataGridTextColumn>
                <DataGridTextColumn Header="易损件条码地址"
                                    Width="Auto"></DataGridTextColumn>
                <DataGridTextColumn Header="录入时间"
                                    Width="Auto"></DataGridTextColumn>
                <DataGridTextColumn Header="操作员"
                                    Width="Auto"></DataGridTextColumn>
                <DataGridCheckBoxColumn Width="Auto"></DataGridCheckBoxColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
