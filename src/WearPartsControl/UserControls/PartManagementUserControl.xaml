<UserControl x:Class="WearPartsControl.UserControls.PartManagementUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:loc="clr-namespace:WearPartsControl.ApplicationServices.Localization"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="1000">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WearPartsControl;component/Resources/ShellContentStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
        <Grid Grid.IsSharedSizeScope="True"
            Background="{StaticResource ShellPanelBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
                <Border Margin="0"
                    Style="{StaticResource ShellSectionHeaderBorderStyle}">
                <TextBlock Style="{StaticResource ShellSectionTitleTextStyle}"
                       Text="{loc:Loc PartManagementControl.Title}" />
            </Border>

                <Border Margin="0 12 0 0"
                    Style="{StaticResource ShellStatusCardBorderStyle}">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <WrapPanel>
                        <TextBlock VerticalAlignment="Center"
                                   Margin="0 0 24 0"
                                   TextWrapping="WrapWithOverflow"
                                   Foreground="{StaticResource InfoBrush}"
                                   FontWeight="SemiBold"
                                   Text="{Binding StatusMessage, Mode=OneWay}" />
                        <TextBlock VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0}{1}">
                                    <Binding Source="{x:Static loc:LocalizationBindingSource.Instance}"
                                             Path="[PartManagementControl.CurrentResourceNumberLabel]"
                                             Mode="OneWay" />
                                    <Binding Path="ResourceNumber" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </WrapPanel>

                          <WrapPanel Grid.Row="1"
                               Style="{StaticResource ShellToolbarWrapPanelStyle}">
                           <Grid Style="{StaticResource ShellToolbarFieldGridStyle}">
                            <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"
                                      SharedSizeGroup="PartManagementFilterLabelColumn" />
                                <ColumnDefinition Width="220" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                   Margin="0 0 8 0"
                                   TextWrapping="Wrap"
                                       Text="{loc:Loc PartManagementControl.PartNameLabel}" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding PartNameFilter, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TextBoxExtend}"
                                     hc:InfoElement.Placeholder="{loc:Loc PartManagementControl.PartNamePlaceholder}" />
                        </Grid>
                        <Button Style="{StaticResource ShellToolbarPrimaryButtonStyle}"
                                Command="{Binding SearchCommand}"
                                hc:IconElement.Geometry="{StaticResource SearchGeometry}"
                                Content="{loc:Loc PartManagementControl.SearchButton}" />
                        <Button Style="{StaticResource ShellToolbarPrimaryButtonStyle}"
                                Command="{Binding RefreshCommand}"
                                Content="{loc:Loc PartManagementControl.RefreshButton}" />
                        <Button Style="{StaticResource ShellToolbarPrimaryButtonStyle}"
                                Command="{Binding AddCommand}"
                                hc:IconElement.Geometry="{StaticResource AddGeometry}"
                                Content="{loc:Loc PartManagementControl.AddButton}" />
                        <Button Style="{StaticResource ShellToolbarPrimaryButtonStyle}"
                                Command="{Binding EditCommand}"
                                hc:IconElement.Geometry="{StaticResource DropperGeometry}"
                                Content="{loc:Loc PartManagementControl.EditButton}" />
                        <Button Style="{StaticResource ShellToolbarPrimaryButtonStyle}"
                                Command="{Binding DeleteCommand}"
                                hc:IconElement.Geometry="{StaticResource DeleteGeometry}"
                                Content="{loc:Loc PartManagementControl.DeleteButton}" />
                        <Button Style="{StaticResource ShellToolbarPrimaryButtonStyle}"
                                Command="{Binding ImportLegacyDefinitionsCommand}"
                                hc:IconElement.Geometry="{StaticResource AddGeometry}"
                                Content="{loc:Loc PartManagementControl.ImportLegacyDefinitionsButton}" />
                    </WrapPanel>
                </Grid>
            </Border>
        </StackPanel>

        <Border Grid.Row="1"
            Margin="0 12 0 0"
                MinHeight="0"
                MinWidth="0"
            ClipToBounds="True"
            Style="{StaticResource ShellCardBorderStyle}">
            <DataGrid AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="False"
                      ItemsSource="{Binding Definitions}"
                      SelectedItem="{Binding SelectedDefinitionRow, Mode=TwoWay}"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.CanContentScroll="True"
                      EnableColumnVirtualization="True"
                      EnableRowVirtualization="True">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Width="SizeToHeader">
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <CheckBox VerticalAlignment="Center"
                                          IsChecked="{Binding DataContext.AreAllDefinitionsChecked, RelativeSource={RelativeSource AncestorType=DataGrid}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Content="{loc:Loc PartManagementControl.CheckedHeader}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.ResourceNumberHeader}"
                                        Binding="{Binding Item.ResourceNumber}"
                                        IsReadOnly="True"
                                        Width="SizeToHeader" />
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.NameHeader}"
                                        Binding="{Binding Item.PartName}"
                                        IsReadOnly="True"
                                        Width="SizeToHeader" />
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.WearPartTypeHeader}"
                                        Binding="{Binding Item.WearPartTypeName}"
                                        IsReadOnly="True"
                                        Width="SizeToHeader" />
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.LifetimeTypeHeader}"
                                        Binding="{Binding Item.LifetimeType}"
                                        IsReadOnly="True"
                                        Width="SizeToHeader" />
                    <DataGridCheckBoxColumn Header="{loc:Loc PartManagementControl.IsShutdownHeader}"
                                            Binding="{Binding Item.IsShutdown}"
                                            IsReadOnly="True"
                                            Width="SizeToHeader" />
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.CurrentValueAddressHeader}"
                                        Binding="{Binding Item.CurrentValueAddress}"
                                        IsReadOnly="True"
                                        Width="SizeToHeader" />
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.CurrentValueDataTypeHeader}"
                                        Binding="{Binding Item.CurrentValueDataType}"
                                        IsReadOnly="True"
                                        Width="SizeToHeader" />
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.WarningValueAddressHeader}"
                                        Binding="{Binding Item.WarningValueAddress}"
                                        IsReadOnly="True"
                                        Width="SizeToHeader" />
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.WarningValueDataTypeHeader}"
                                        Binding="{Binding Item.WarningValueDataType}"
                                        IsReadOnly="True"
                                        Width="SizeToHeader" />
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.ShutdownValueAddressHeader}"
                                        Binding="{Binding Item.ShutdownValueAddress}"
                                        IsReadOnly="True"
                                        Width="SizeToHeader" />
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.ShutdownValueDataTypeHeader}"
                                        Binding="{Binding Item.ShutdownValueDataType}"
                                        IsReadOnly="True"
                                        Width="SizeToHeader" />
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.InputModeHeader}"
                                        Binding="{Binding Item.InputMode}"
                                        IsReadOnly="True"
                                        Width="SizeToHeader" />
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.CodeMinLengthHeader}"
                                        Binding="{Binding Item.CodeMinLength}"
                                        IsReadOnly="True"
                                        Width="SizeToHeader" />
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.CodeMaxLengthHeader}"
                                        Binding="{Binding Item.CodeMaxLength}"
                                        IsReadOnly="True"
                                        Width="SizeToHeader" />
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.PlcZeroClearAddressHeader}"
                                        Binding="{Binding Item.PlcZeroClearAddress}"
                                        IsReadOnly="True"
                                        Width="SizeToHeader" />
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.BarcodeWriteAddressHeader}"
                                        Binding="{Binding Item.BarcodeWriteAddress}"
                                        IsReadOnly="True"
                                        Width="SizeToHeader" />
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.CreatedAtHeader}"
                                        Binding="{Binding Item.CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                                        IsReadOnly="True"
                                        Width="SizeToHeader" />
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.CreatedByHeader}"
                                        Binding="{Binding Item.CreatedBy}"
                                        IsReadOnly="True"
                                        Width="SizeToHeader" />
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.UpdatedAtHeader}"
                                        Binding="{Binding Item.UpdatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                                        IsReadOnly="True"
                                        Width="SizeToHeader" />
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.UpdatedByHeader}"
                                        Binding="{Binding Item.UpdatedBy}"
                                        IsReadOnly="True"
                                        Width="SizeToHeader" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

    </Grid>
</UserControl>
