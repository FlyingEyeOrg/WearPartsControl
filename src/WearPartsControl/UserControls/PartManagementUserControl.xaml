<UserControl x:Class="WearPartsControl.UserControls.PartManagementUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d"
             d:DesignHeight="450"
         d:DesignWidth="1000">
    <Grid MinHeight="0"
        MinWidth="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <Border Background="#FF365082"
                    Padding="0 4">
                <TextBlock HorizontalAlignment="Center"
                           FontWeight="Bold"
                           FontSize="16"
                           Foreground="White">易损件管理</TextBlock>
            </Border>

            <Border Margin="8 8 8 0"
                    CornerRadius="6"
                    Background="#FFF5F7FA"
                    BorderBrush="#FFD9E2F2"
                    BorderThickness="1">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel LastChildFill="False">
                        <TextBlock VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Text="{Binding StatusMessage}" />
                        <TextBlock Margin="24 0 0 0"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Text="{Binding ResourceNumber, StringFormat=当前资源号：{0}}" />
                    </DockPanel>

                    <WrapPanel Grid.Row="1"
                               Margin="0 8 0 0"
                               VerticalAlignment="Center">
                        <Grid Margin="0 8 8 0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="180" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center">易损件名称：</TextBlock>
                            <TextBox Grid.Column="1"
                                     Text="{Binding PartNameFilter, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TextBoxExtend}"
                                     hc:InfoElement.Placeholder="请输入易损件名称" />
                        </Grid>
                        <Button Margin="0 8 8 0"
                                Width="80"
                                Command="{Binding SearchCommand}"
                                Style="{StaticResource ButtonPrimary}"
                                hc:IconElement.Geometry="{StaticResource SearchGeometry}">查询</Button>
                        <Button Margin="0 8 8 0"
                                Width="80"
                                Command="{Binding RefreshCommand}"
                                Style="{StaticResource ButtonPrimary}">刷新</Button>
                        <Button Margin="0 8 8 0"
                                Width="80"
                                Command="{Binding AddCommand}"
                                Style="{StaticResource ButtonPrimary}"
                                hc:IconElement.Geometry="{StaticResource AddGeometry}">新增</Button>
                        <Button Margin="0 8 8 0"
                                Width="80"
                                Command="{Binding EditCommand}"
                                Style="{StaticResource ButtonPrimary}"
                                hc:IconElement.Geometry="{StaticResource DropperGeometry}">编辑</Button>
                        <Button Margin="0 8 8 0"
                                Width="80"
                                Command="{Binding DeleteCommand}"
                                Style="{StaticResource ButtonPrimary}"
                                hc:IconElement.Geometry="{StaticResource DeleteGeometry}">删除</Button>
                        <Button Margin="0 8 8 0"
                                IsEnabled="False"
                                Style="{StaticResource ButtonPrimary}"
                                ToolTip="导入功能保留原入口，当前未在本次 CRUD 范围内调整。"
                                hc:IconElement.Geometry="{StaticResource AddGeometry}">从其他设备导入</Button>
                    </WrapPanel>
                </Grid>
            </Border>
        </StackPanel>

        <Border Grid.Row="1"
            Margin="8"
            MinHeight="0"
            MinWidth="0"
            ClipToBounds="True">
            <DataGrid AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  ItemsSource="{Binding Definitions}"
                  SelectedItem="{Binding SelectedDefinition, Mode=TwoWay}"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.CanContentScroll="True"
                  EnableColumnVirtualization="True"
                  EnableRowVirtualization="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="资源号"
                                    Binding="{Binding ResourceNumber}"
                                    Width="120" />
                <DataGridTextColumn Header="名称"
                                    Binding="{Binding PartName}"
                                    Width="140" />
                <DataGridTextColumn Header="寿命类型"
                                    Binding="{Binding LifetimeType}"
                                    Width="90" />
                <DataGridCheckBoxColumn Header="到期停机"
                                        Binding="{Binding IsShutdown}"
                                        Width="80" />
                <DataGridTextColumn Header="当前寿命地址"
                                    Binding="{Binding CurrentValueAddress}"
                                    Width="120" />
                <DataGridTextColumn Header="当前寿命数据类型"
                                    Binding="{Binding CurrentValueDataType}"
                                    Width="120" />
                <DataGridTextColumn Header="预警寿命地址"
                                    Binding="{Binding WarningValueAddress}"
                                    Width="120" />
                <DataGridTextColumn Header="预警寿命数据类型"
                                    Binding="{Binding WarningValueDataType}"
                                    Width="120" />
                <DataGridTextColumn Header="停机寿命地址"
                                    Binding="{Binding ShutdownValueAddress}"
                                    Width="120" />
                <DataGridTextColumn Header="停机寿命数据类型"
                                    Binding="{Binding ShutdownValueDataType}"
                                    Width="120" />
                <DataGridTextColumn Header="输入方式"
                                    Binding="{Binding InputMode}"
                                    Width="90" />
                <DataGridTextColumn Header="条码最小长度"
                                    Binding="{Binding CodeMinLength}"
                                    Width="90" />
                <DataGridTextColumn Header="条码最大长度"
                                    Binding="{Binding CodeMaxLength}"
                                    Width="90" />
                <DataGridTextColumn Header="附加清零地址"
                                    Binding="{Binding PlcZeroClearAddress}"
                                    Width="120" />
                <DataGridTextColumn Header="易损件条码地址"
                                    Binding="{Binding BarcodeWriteAddress}"
                                    Width="120" />
                <DataGridTextColumn Header="创建时间"
                                    Binding="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                                    Width="150" />
                <DataGridTextColumn Header="创建人"
                                    Binding="{Binding CreatedBy}"
                                    Width="100" />
                <DataGridTextColumn Header="更新时间"
                                    Binding="{Binding UpdatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                                    Width="150" />
                <DataGridTextColumn Header="更新人"
                                    Binding="{Binding UpdatedBy}"
                                    Width="100" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

    </Grid>
</UserControl>
