<UserControl x:Class="WearPartsControl.UserControls.PartManagementUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:loc="clr-namespace:WearPartsControl.ApplicationServices.Localization"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="1000">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <Border Background="#FF365082"
                    Padding="0 8">
                <TextBlock HorizontalAlignment="Center"
                           FontWeight="Bold"
                           FontSize="16"
                           Foreground="White"
                           Text="{loc:Loc PartManagementControl.Title}" />
            </Border>

            <Border Margin="8 8 8 0"
                    CornerRadius="6"
                    Background="#FFF5F7FA"
                    BorderBrush="#FFD9E2F2"
                    BorderThickness="1">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel LastChildFill="False">
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{StaticResource InfoBrush}"
                                   FontWeight="SemiBold"
                                   Text="{Binding StatusMessage, Mode=OneWay}" />
                        <TextBlock Margin="24 0 0 0"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0}{1}">
                                    <Binding Source="{x:Static loc:LocalizationBindingSource.Instance}"
                                             Path="[PartManagementControl.CurrentResourceNumberLabel]"
                                             Mode="OneWay" />
                                    <Binding Path="ResourceNumber" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </DockPanel>

                    <WrapPanel Grid.Row="1"
                               Margin="0 8 0 0"
                               VerticalAlignment="Center">
                        <Grid Margin="0 8 8 0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="180" />
                            </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center"
                                       Text="{loc:Loc PartManagementControl.PartNameLabel}" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding PartNameFilter, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TextBoxExtend}"
                                     hc:InfoElement.Placeholder="{loc:Loc PartManagementControl.PartNamePlaceholder}" />
                        </Grid>
                        <Button Margin="0 8 8 0"
                                Width="80"
                                Command="{Binding SearchCommand}"
                                Style="{StaticResource ButtonPrimary}"
                                hc:IconElement.Geometry="{StaticResource SearchGeometry}"
                                Content="{loc:Loc PartManagementControl.SearchButton}" />
                        <Button Margin="0 8 8 0"
                                Width="80"
                                Command="{Binding RefreshCommand}"
                                Style="{StaticResource ButtonPrimary}"
                                Content="{loc:Loc PartManagementControl.RefreshButton}" />
                        <Button Margin="0 8 8 0"
                                Width="80"
                                Command="{Binding AddCommand}"
                                Style="{StaticResource ButtonPrimary}"
                                hc:IconElement.Geometry="{StaticResource AddGeometry}"
                                Content="{loc:Loc PartManagementControl.AddButton}" />
                        <Button Margin="0 8 8 0"
                                Width="80"
                                Command="{Binding EditCommand}"
                                Style="{StaticResource ButtonPrimary}"
                                hc:IconElement.Geometry="{StaticResource DropperGeometry}"
                                Content="{loc:Loc PartManagementControl.EditButton}" />
                        <Button Margin="0 8 8 0"
                                Width="80"
                                Command="{Binding DeleteCommand}"
                                Style="{StaticResource ButtonPrimary}"
                                hc:IconElement.Geometry="{StaticResource DeleteGeometry}"
                                Content="{loc:Loc PartManagementControl.DeleteButton}" />
                        <Button Margin="0 8 8 0"
                            Command="{Binding ImportLegacyDefinitionsCommand}"
                            Style="{StaticResource ButtonPrimary}"
                                hc:IconElement.Geometry="{StaticResource AddGeometry}"
                                Content="{loc:Loc PartManagementControl.ImportLegacyDefinitionsButton}" />
                    </WrapPanel>
                </Grid>
            </Border>
        </StackPanel>

        <Border Grid.Row="1"
                Margin="8"
                MinHeight="0"
                MinWidth="0"
                ClipToBounds="True">
            <DataGrid AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      ItemsSource="{Binding Definitions}"
                      SelectedItem="{Binding SelectedDefinition, Mode=TwoWay}"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.CanContentScroll="True"
                      EnableColumnVirtualization="True"
                      EnableRowVirtualization="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.ResourceNumberHeader}"
                                        Binding="{Binding ResourceNumber}"
                                        Width="120" />
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.NameHeader}"
                                        Binding="{Binding PartName}"
                                        Width="140" />
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.LifetimeTypeHeader}"
                                        Binding="{Binding LifetimeType}"
                                        Width="90" />
                    <DataGridCheckBoxColumn Header="{loc:Loc PartManagementControl.IsShutdownHeader}"
                                            Binding="{Binding IsShutdown}"
                                            Width="80" />
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.CurrentValueAddressHeader}"
                                        Binding="{Binding CurrentValueAddress}"
                                        Width="120" />
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.CurrentValueDataTypeHeader}"
                                        Binding="{Binding CurrentValueDataType}"
                                        Width="120" />
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.WarningValueAddressHeader}"
                                        Binding="{Binding WarningValueAddress}"
                                        Width="120" />
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.WarningValueDataTypeHeader}"
                                        Binding="{Binding WarningValueDataType}"
                                        Width="120" />
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.ShutdownValueAddressHeader}"
                                        Binding="{Binding ShutdownValueAddress}"
                                        Width="120" />
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.ShutdownValueDataTypeHeader}"
                                        Binding="{Binding ShutdownValueDataType}"
                                        Width="120" />
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.InputModeHeader}"
                                        Binding="{Binding InputMode}"
                                        Width="90" />
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.CodeMinLengthHeader}"
                                        Binding="{Binding CodeMinLength}"
                                        Width="90" />
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.CodeMaxLengthHeader}"
                                        Binding="{Binding CodeMaxLength}"
                                        Width="90" />
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.PlcZeroClearAddressHeader}"
                                        Binding="{Binding PlcZeroClearAddress}"
                                        Width="120" />
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.BarcodeWriteAddressHeader}"
                                        Binding="{Binding BarcodeWriteAddress}"
                                        Width="120" />
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.CreatedAtHeader}"
                                        Binding="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                                        Width="150" />
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.CreatedByHeader}"
                                        Binding="{Binding CreatedBy}"
                                        Width="100" />
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.UpdatedAtHeader}"
                                        Binding="{Binding UpdatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                                        Width="150" />
                    <DataGridTextColumn Header="{loc:Loc PartManagementControl.UpdatedByHeader}"
                                        Binding="{Binding UpdatedBy}"
                                        Width="100" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

    </Grid>
</UserControl>
