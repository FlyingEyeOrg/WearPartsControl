<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <LinearGradientBrush x:Key="ShellPanelBackgroundBrush"
                         StartPoint="0,0"
                         EndPoint="1,1">
        <GradientStop Color="#FFF7FAFC"
                      Offset="0" />
        <GradientStop Color="#FFF1F5FA"
                      Offset="0.55" />
        <GradientStop Color="#FFEAF0F7"
                      Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ShellHeaderBackgroundBrush"
                         StartPoint="0,0"
                         EndPoint="1,1">
        <GradientStop Color="#FF29446E"
                      Offset="0" />
        <GradientStop Color="#FF3C6C97"
                      Offset="0.55" />
        <GradientStop Color="#FF6A9CC2"
                      Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="ShellCardBackgroundBrush" Color="#FDFDFEFF" />
    <SolidColorBrush x:Key="ShellCardBorderBrush" Color="#FFD5E0EC" />
    <SolidColorBrush x:Key="ShellMutedForegroundBrush" Color="#FF5B6B7A" />
    <Style x:Key="ShellSectionHeaderBorderStyle"
           TargetType="Border">
        <Setter Property="Background"
                Value="{StaticResource ShellHeaderBackgroundBrush}" />
        <Setter Property="CornerRadius"
                Value="18" />
        <Setter Property="Padding"
                Value="20 14" />
    </Style>
    <Style x:Key="ShellSectionTitleTextStyle"
           TargetType="TextBlock">
        <Setter Property="Foreground"
                Value="White" />
        <Setter Property="FontWeight"
                Value="Bold" />
        <Setter Property="FontSize"
                Value="18" />
        <Setter Property="HorizontalAlignment"
                Value="Center" />
    </Style>
    <Style x:Key="ShellCardBorderStyle"
           TargetType="Border">
        <Setter Property="Background"
                Value="{StaticResource ShellCardBackgroundBrush}" />
        <Setter Property="BorderBrush"
                Value="{StaticResource ShellCardBorderBrush}" />
        <Setter Property="BorderThickness"
                Value="1" />
        <Setter Property="CornerRadius"
                Value="18" />
        <Setter Property="Padding"
                Value="18" />
    </Style>
    <Style x:Key="ShellSurfaceBorderStyle"
           TargetType="Border"
           BasedOn="{StaticResource ShellCardBorderStyle}">
        <Setter Property="Background"
                Value="{StaticResource ShellPanelBackgroundBrush}" />
    </Style>
    <Style x:Key="ShellFormSectionCardBorderStyle"
           TargetType="Border"
           BasedOn="{StaticResource ShellCardBorderStyle}">
        <Setter Property="Padding"
                Value="16" />
    </Style>
    <Style x:Key="ShellStatusCardBorderStyle"
           TargetType="Border"
           BasedOn="{StaticResource ShellCardBorderStyle}">
        <Setter Property="Background"
                Value="#FFF7FAFD" />
        <Setter Property="BorderBrush"
                Value="#FFD9E7F4" />
    </Style>
    <Style x:Key="ShellSectionLabelTextStyle"
           TargetType="TextBlock">
        <Setter Property="FontWeight"
                Value="SemiBold" />
        <Setter Property="Foreground"
                Value="#FF365082" />
        <Setter Property="Margin"
                Value="0 0 0 10" />
    </Style>
    <Style x:Key="ShellFormSectionTitleTextStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource ShellSectionLabelTextStyle}">
        <Setter Property="FontSize"
                Value="15" />
        <Setter Property="Margin"
                Value="0 0 0 12" />
    </Style>
</ResourceDictionary>