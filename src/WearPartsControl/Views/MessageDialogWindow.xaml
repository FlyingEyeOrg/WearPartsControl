<local:AppDialogWindow x:Class="WearPartsControl.Views.MessageDialogWindow"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                       xmlns:local="clr-namespace:WearPartsControl.Views"
                       mc:Ignorable="d"
                       Width="520"
                       MinWidth="420"
                       MaxWidth="620"
                       SizeToContent="Height">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WearPartsControl;component/Resources/ShellContentStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <SolidColorBrush x:Key="DialogSurfaceBrush" Color="#FFFDFEFF" />
            <Style x:Key="DialogSecondaryButtonStyle"
                   TargetType="Button">
                <Setter Property="MinWidth"
                        Value="96" />
                <Setter Property="Padding"
                        Value="18 6" />
                <Setter Property="Margin"
                        Value="0 0 10 0" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    <Border Margin="1"
            Background="{StaticResource DialogSurfaceBrush}"
            BorderBrush="{StaticResource ShellCardBorderBrush}"
            BorderThickness="1"
            CornerRadius="22">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Margin="24 24 24 20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <Border x:Name="AccentBar"
                                Width="72"
                                Height="6"
                                HorizontalAlignment="Left"
                                CornerRadius="3" />
                        <Border x:Name="GlyphBorder"
                                Width="52"
                                Height="52"
                                Margin="0 18 0 0"
                                CornerRadius="26"
                                VerticalAlignment="Top">
                            <TextBlock x:Name="GlyphTextBlock"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="White" />
                        </Border>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#1E3550"
                                   TextWrapping="Wrap"
                                   Text="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Title}" />
                        <TextBlock x:Name="MessageTextBlock"
                                   Margin="0 12 0 0"
                                   TextWrapping="Wrap"
                                   Foreground="#42586C"
                                   FontSize="14"
                                   LineHeight="22" />
                    </StackPanel>
                </Grid>
            </Grid>

            <Border Grid.Row="1"
                    Padding="24 18 24 22"
                    Background="#F6FAFD"
                    BorderBrush="#E1EAF2"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,22,22">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="TertiaryButton"
                            Style="{StaticResource DialogSecondaryButtonStyle}"
                            Visibility="Collapsed"
                            Click="OnTertiaryButtonClick" />
                    <Button x:Name="SecondaryButton"
                            Style="{StaticResource DialogSecondaryButtonStyle}"
                            Visibility="Collapsed"
                            Click="OnSecondaryButtonClick" />
                    <Button x:Name="PrimaryButton"
                            MinWidth="110"
                            Padding="20 6"
                            Style="{StaticResource ButtonPrimary}"
                            Visibility="Collapsed"
                            Click="OnPrimaryButtonClick" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</local:AppDialogWindow>