<local:AppDialogWindow x:Class="WearPartsControl.Views.MessageDialogWindow"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                       xmlns:local="clr-namespace:WearPartsControl.Views"
                       mc:Ignorable="d"
                       Width="520"
                       MinWidth="420"
                       MaxWidth="620"
                       SizeToContent="Height">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WearPartsControl;component/Resources/ShellContentStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <SolidColorBrush x:Key="DialogSurfaceBrush" Color="#FFFDFEFF" />
        </ResourceDictionary>
    </Window.Resources>
        <Border Margin="1"
            Background="{StaticResource DialogSurfaceBrush}"
            BorderBrush="{StaticResource ShellCardBorderBrush}"
            BorderThickness="1"
            CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border x:Name="HeaderBorder"
                    Padding="18 14"
                    Background="{StaticResource ShellHeaderBackgroundBrush}"
                    CornerRadius="10 10 0 0">
                <TextBlock x:Name="TitleTextBlock"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="White" />
            </Border>

            <Grid Grid.Row="1"
                Margin="18 16 18 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border x:Name="GlyphBorder"
                    Width="36"
                    Height="36"
                    CornerRadius="18"
                        VerticalAlignment="Top">
                    <TextBlock x:Name="GlyphTextBlock"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="White" />
                </Border>
                <TextBlock x:Name="MessageTextBlock"
                           Grid.Column="2"
                           TextWrapping="Wrap"
                           Foreground="#1F3348"
                           FontSize="14"
                           LineHeight="22" />
            </Grid>

            <StackPanel Grid.Row="2"
                           Margin="18 18 18 18"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="TertiaryButton"
                        MinWidth="96"
                        Margin="0 0 8 0"
                        Visibility="Collapsed"
                        Click="OnTertiaryButtonClick" />
                <Button x:Name="SecondaryButton"
                        MinWidth="96"
                        Margin="0 0 8 0"
                        Visibility="Collapsed"
                        Click="OnSecondaryButtonClick" />
                <Button x:Name="PrimaryButton"
                        MinWidth="110"
                        Style="{StaticResource ButtonPrimary}"
                        Visibility="Collapsed"
                        Click="OnPrimaryButtonClick" />
            </StackPanel>
        </Grid>
    </Border>
</local:AppDialogWindow>