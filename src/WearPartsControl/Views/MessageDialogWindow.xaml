<local:AppDialogWindow x:Class="WearPartsControl.Views.MessageDialogWindow"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                       xmlns:local="clr-namespace:WearPartsControl.Views"
                       mc:Ignorable="d"
                       Width="520"
                       MinWidth="420"
                       MaxWidth="620"
                       SizeToContent="Height">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WearPartsControl;component/Resources/ShellContentStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <SolidColorBrush x:Key="DialogSurfaceBrush"
                             Color="#FFFDFEFF" />
        </ResourceDictionary>
    </Window.Resources>
    <Border Margin="1"
            Background="{StaticResource DialogSurfaceBrush}"
            BorderBrush="{StaticResource ShellCardBorderBrush}"
            BorderThickness="1"
            CornerRadius="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Margin="24 24 24 20">
                <TextBlock Margin="0 18 0 0"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#1E3550"
                           TextWrapping="Wrap"
                           Text="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Title}" />
                <TextBlock x:Name="MessageTextBlock"
                           Margin="0 12 0 0"
                           TextWrapping="Wrap"
                           Foreground="#42586C"
                           FontSize="14"
                           LineHeight="22" />
            </StackPanel>

            <Border Grid.Row="1"
                    Padding="24 18 24 22"
                    Background="#F6FAFD"
                    BorderBrush="#E1EAF2"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="TertiaryButton"
                            MinWidth="96"
                            Padding="18 6"
                            Margin="0 0 10 0"
                            Style="{StaticResource ButtonDefault}"
                            Visibility="Collapsed"
                            Click="OnTertiaryButtonClick" />
                    <Button x:Name="SecondaryButton"
                            MinWidth="96"
                            Padding="18 6"
                            Margin="0 0 10 0"
                            Style="{StaticResource ButtonDefault}"
                            Visibility="Collapsed"
                            Click="OnSecondaryButtonClick" />
                    <Button x:Name="PrimaryButton"
                            MinWidth="110"
                            Padding="20 6"
                            Style="{StaticResource ButtonPrimary}"
                            Visibility="Collapsed"
                            Click="OnPrimaryButtonClick" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</local:AppDialogWindow>