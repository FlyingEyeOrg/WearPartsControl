<views:AppDialogWindow x:Class="WearPartsControl.Views.NotificationPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="clr-namespace:WearPartsControl.ApplicationServices.Localization"
        xmlns:views="clr-namespace:WearPartsControl.Views"
        mc:Ignorable="d"
        Title="{loc:Loc UserConfigControl.NotificationPreviewWindowTitle}"
        Width="860"
        Height="700"
        MinWidth="760"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WearPartsControl;component/Resources/ShellContentStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Border Margin="10"
            Style="{StaticResource ShellSurfaceBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource ShellStatusCardBorderStyle}">
                <TextBlock Text="{loc:Loc UserConfigControl.NotificationPreviewHint}"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource InfoBrush}"
                           FontWeight="SemiBold" />
            </Border>

            <TabControl Grid.Row="1"
                        Margin="0 12 0 0">
                <TabItem Header="{loc:Loc UserConfigControl.WarningNotificationPreviewTab}">
                    <Border Padding="12"
                            Background="White">
                        <FlowDocumentScrollViewer x:Name="WarningPreviewViewer"
                                                  VerticalScrollBarVisibility="Auto"
                                                  IsToolBarVisible="False"
                                                  BorderThickness="0"
                                                  Background="Transparent"
                                                  Foreground="#1F3348" />
                    </Border>
                </TabItem>
                <TabItem Header="{loc:Loc UserConfigControl.ShutdownNotificationPreviewTab}">
                    <Border Padding="12"
                            Background="White">
                        <FlowDocumentScrollViewer x:Name="ShutdownPreviewViewer"
                                                  VerticalScrollBarVisibility="Auto"
                                                  IsToolBarVisible="False"
                                                  BorderThickness="0"
                                                  Background="Transparent"
                                                  Foreground="#1F3348" />
                    </Border>
                </TabItem>
            </TabControl>

            <StackPanel Grid.Row="2"
                        Margin="0 12 0 0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button MinWidth="120"
                        Style="{StaticResource ButtonPrimary}"
                        Content="{loc:Loc UserConfigControl.NotificationPreviewCloseButton}"
                        Click="OnCloseClicked" />
            </StackPanel>
        </Grid>
    </Border>
</views:AppDialogWindow>