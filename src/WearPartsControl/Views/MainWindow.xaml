<Window x:Class="WearPartsControl.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WearPartsControl.Views"
        xmlns:uc="clr-namespace:WearPartsControl.UserControls"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:vm="clr-namespace:WearPartsControl.ViewModels"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="600"
        MinWidth="980"
        Width="980"
        Background="AliceBlue"
        Icon="pack://application:,,,/WearPartsControl;component/Assets/app.ico"
        ShowInTaskbar="True"
        d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel}">
    <Grid>
        <Grid IsEnabled="{Binding IsNotBusy}">
            <Grid.RowDefinitions>
                <RowDefinition  Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel>
                <Grid x:Name="TitleBarGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="1" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="1" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel x:Name="LogoPanel"
                                Background="White"
                                Orientation="Horizontal">
                        <Image x:Name="LogoImage"
                               Source="pack://application:,,,/WearPartsControl;component/Assets/catl.ico"
                               Width="240" />
                    </StackPanel>
                    <Border Grid.Column="1"
                            Width="1"
                            Background="{StaticResource PrimaryBrush}" />
                    <TextBlock x:Name="TitleLabel"
                               Margin="8 0 8 0"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Grid.Column="2"
                               FontSize="40"
                               FontWeight="Bold"
                               Text="{Binding BrandTitle, Mode=OneWay}" />
                    <Border Grid.Column="3"
                            Width="1"
                            Background="{StaticResource PrimaryBrush}" />
                    <uc:LoginBox x:Name="LoginBoxControl"
                                 Margin="8"
                                 Width="360"
                                 IsEnabled="{Binding IsClientAppInfoConfigured}"
                                 Grid.Column="4" />
                </Grid>
                <Grid Height="1"
                      Background="{StaticResource PrimaryBrush}"></Grid>
            </StackPanel>
            <uc:UserTabControl Grid.Row="1"
                               Headers="{Binding Tabs}"
                               TabIndex="0"
                               SelectedContent="{Binding SelectedContent, Mode=OneWay}"
                               Command="{Binding TabChangedCommand}" />
        </Grid>
        <Border Background="#40FFFFFF"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel>
                <hc:LoadingCircle Width="60"
                                  Height="60"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  IsRunning="{Binding IsBusy}" />
                <TextBlock HorizontalAlignment="Center"
                           Style="{StaticResource TextBlockDefaultPrimary}"
                           Margin="0 8 0 0"
                           Text="{Binding LoadingText, Mode=OneWay}"
                           Visibility="{Binding HasLoadingText, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
