<views:AppDialogWindow x:Class="WearPartsControl.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:loc="clr-namespace:WearPartsControl.ApplicationServices.Localization"
        xmlns:views="clr-namespace:WearPartsControl.Views"
        mc:Ignorable="d"
        Title="{loc:Loc LoginWindowView.Title}"
        Height="420"
        Width="860"
        MinWidth="760"
        MinHeight="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WearPartsControl;component/Resources/ShellContentStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <LinearGradientBrush x:Key="LoginWindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#E8F2FA" Offset="0" />
                <GradientStop Color="#F7FBFF" Offset="1" />
            </LinearGradientBrush>
            <ImageBrush x:Key="LoginWindowHeroImageBrush"
                        ImageSource="pack://application:,,,/WearPartsControl;component/Assets/loginwindow-background.png"
                        Stretch="UniformToFill" />
            <LinearGradientBrush x:Key="LoginWindowHeroOverlayBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#CC0F2D4D" Offset="0" />
                <GradientStop Color="#B3174B74" Offset="0.52" />
                <GradientStop Color="#D8216AA1" Offset="1" />
            </LinearGradientBrush>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Background="{StaticResource LoginWindowBackgroundBrush}">
        <Grid>
            <Rectangle Fill="{StaticResource LoginWindowHeroImageBrush}"
                       Opacity="0.1" />
            <Rectangle Fill="{StaticResource LoginWindowHeroOverlayBrush}"
                       Opacity="0.08" />
            <Border Width="520"
                    Margin="20"
                    Padding="28"
                    Background="#FCFEFF"
                    BorderBrush="#D8E5F0"
                    BorderThickness="1"
                    CornerRadius="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel>
                           <Image Source="pack://application:,,,/WearPartsControl;component/Assets/catl.ico"
                               Width="72"
                               HorizontalAlignment="Center"
                               Opacity="0.9" />
                        <TextBlock Margin="0 18 0 0"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="#1E3550"
                                   TextAlignment="Center"
                                   Text="{Binding LoginPrompt}" />
                        <TextBlock Margin="0 10 0 0"
                                   FontSize="14"
                                   Foreground="#64788C"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Text="{loc:Loc LoginWindowView.HeroHint}" />
                    </StackPanel>

                    <Border Grid.Row="1"
                            Margin="0 22 0 0"
                            Style="{StaticResource ShellStatusCardBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Foreground="#6A7E91"
                                           Text="{loc:Loc LoginWindowView.ResourceNumberLabel}" />
                                <TextBlock Margin="0 4 0 0"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="#20405F"
                                           Text="{Binding ResourceNumber, Mode=OneWay}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Foreground="#6A7E91"
                                           Text="{loc:Loc LoginWindowView.SiteLabel}" />
                                <TextBlock Margin="0 4 0 0"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="#20405F"
                                           Text="{Binding SiteCode, Mode=OneWay}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            Margin="0 18 0 0"
                            Style="{StaticResource ShellActionCardBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <PasswordBox x:Name="PasswordInputBox"
                                             Height="42"
                                             Padding="12 0"
                                             VerticalContentAlignment="Center"
                                             PasswordChanged="PasswordInputBox_OnPasswordChanged"
                                             PreviewKeyDown="PasswordInputBox_OnPreviewKeyDown"
                                             PreviewTextInput="PasswordInputBox_OnPreviewTextInput"
                                             DataObject.Pasting="PasswordInputBox_OnPasting" />
                                <Button Grid.Column="1"
                                        Margin="12 0 0 0"
                                        MinWidth="128"
                                        Height="42"
                                        Padding="20 0"
                                        Style="{StaticResource ButtonPrimary}"
                                        Command="{Binding LoginCommand}"
                                        Content="{loc:Loc LoginWindowView.LoginButton}" />
                            </Grid>
                            <TextBlock Grid.Row="1"
                                       Margin="0 12 0 0"
                                       MinHeight="32"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       VerticalAlignment="Top"
                                       Foreground="#2F4E68"
                                       Text="{Binding StatusMessage}" />
                        </Grid>
                    </Border>

                    <TextBlock Grid.Row="3"
                               Margin="0 16 0 0"
                               Foreground="#6A7E91"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Text="{loc:Loc LoginWindowView.HeroSubtitle}" />
                </Grid>
            </Border>
            <Border Background="#40FFFFFF"
                    Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                <hc:LoadingCircle Width="60"
                                  Height="60"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  IsRunning="{Binding IsBusy}" />
            </Border>
        </Grid>
    </Grid>
</views:AppDialogWindow>
