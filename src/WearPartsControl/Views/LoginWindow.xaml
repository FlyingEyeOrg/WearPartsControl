<views:AppDialogWindow x:Class="WearPartsControl.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:loc="clr-namespace:WearPartsControl.ApplicationServices.Localization"
        xmlns:views="clr-namespace:WearPartsControl.Views"
        mc:Ignorable="d"
        Title="{loc:Loc LoginWindowView.Title}"
        Height="420"
        Width="860"
        MinWidth="760"
        MinHeight="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <LinearGradientBrush x:Key="LoginWindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#E8F2FA" Offset="0" />
            <GradientStop Color="#F7FBFF" Offset="1" />
        </LinearGradientBrush>
        <ImageBrush x:Key="LoginWindowHeroImageBrush"
                    ImageSource="pack://application:,,,/WearPartsControl;component/Assets/loginwindow-background.png"
                    Stretch="UniformToFill" />
        <LinearGradientBrush x:Key="LoginWindowHeroOverlayBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#CC0F2D4D" Offset="0" />
            <GradientStop Color="#B3174B74" Offset="0.52" />
            <GradientStop Color="#D8216AA1" Offset="1" />
        </LinearGradientBrush>
    </Window.Resources>
    <Grid Background="{StaticResource LoginWindowBackgroundBrush}">
        <Border Margin="10"
                Background="#FCFEFF"
                BorderBrush="#D8E5F0"
                BorderThickness="1"
            CornerRadius="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border CornerRadius="0"
                        Background="{StaticResource LoginWindowHeroImageBrush}">
                    <Grid>
                        <Rectangle Fill="{StaticResource LoginWindowHeroOverlayBrush}" />
                        <Grid Margin="28">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Image Source="pack://application:,,,/WearPartsControl;component/Assets/catl-logo-white.png"
                                   Width="180"
                                   VerticalAlignment="Top"
                                   HorizontalAlignment="Left" />
                            <StackPanel Grid.Row="1"
                                        VerticalAlignment="Center"
                                        Margin="0 28 0 0">
                                <TextBlock FontSize="30"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Text="{loc:Loc LoginWindowView.HeroTitle}" />
                                <TextBlock Margin="0 12 0 0"
                                           FontSize="15"
                                           Foreground="#E4F0FA"
                                           TextWrapping="Wrap"
                                           Text="{loc:Loc LoginWindowView.HeroSubtitle}" />
                            </StackPanel>
                            <Border Grid.Row="2"
                                    Padding="18"
                                    Background="#1FF8FBFF"
                                    BorderBrush="#36FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="18">
                                <TextBlock Foreground="#F6FBFF"
                                           FontSize="14"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="{loc:Loc LoginWindowView.HeroHint}" />
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
                <Grid Grid.Column="1">
                    <Border Margin="18"
                        Padding="18"
                            Background="White"
                            BorderBrush="#E4EDF5"
                            BorderThickness="1"
                        CornerRadius="18">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock FontSize="26"
                                       FontWeight="Bold"
                                       Foreground="#1E3550"
                                       TextAlignment="Center"
                                       Text="{Binding LoginPrompt}" />
                            <Border Grid.Row="1"
                                    Margin="0 16 0 0"
                                    Padding="14 12"
                                    Background="#F4F8FB"
                                    CornerRadius="14">
                                <StackPanel>
                                    <TextBlock HorizontalAlignment="Center"
                                               Foreground="#5D7388">
                                        <Run Text="{loc:Loc LoginWindowView.ResourceNumberLabel}" />
                                        <Run Text="{Binding ResourceNumber, Mode=OneWay}" />
                                    </TextBlock>
                                    <TextBlock Margin="0 4 0 0"
                                               HorizontalAlignment="Center"
                                               Foreground="#5D7388">
                                        <Run Text="{loc:Loc LoginWindowView.SiteLabel}" />
                                        <Run Text="{Binding SiteCode, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <Grid Grid.Row="2"
                                  Margin="0 16 0 0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <PasswordBox x:Name="PasswordInputBox"
                                             Height="40"
                                             Padding="10 0"
                                             VerticalContentAlignment="Center"
                                             PasswordChanged="PasswordInputBox_OnPasswordChanged"
                                             PreviewKeyDown="PasswordInputBox_OnPreviewKeyDown"
                                             PreviewTextInput="PasswordInputBox_OnPreviewTextInput"
                                             DataObject.Pasting="PasswordInputBox_OnPasting" />
                                <Button Grid.Column="1"
                                            Margin="12 0 0 0"
                                        MinWidth="104"
                                        Height="40"
                                        Padding="18 0"
                                        Style="{StaticResource ButtonPrimary}"
                                        Command="{Binding LoginCommand}"
                                        Content="{loc:Loc LoginWindowView.LoginButton}" />
                            </Grid>
                            <TextBlock Grid.Row="3"
                                           Margin="0 14 0 0"
                                       MinHeight="44"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       VerticalAlignment="Top"
                                       Foreground="#2F4E68"
                                       Text="{Binding StatusMessage}" />
                        </Grid>
                    </Border>
                    <Border Background="#40FFFFFF"
                            Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <hc:LoadingCircle Width="60"
                                          Height="60"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          IsRunning="{Binding IsBusy}" />
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</views:AppDialogWindow>
