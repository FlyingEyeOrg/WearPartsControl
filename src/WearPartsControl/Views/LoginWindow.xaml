<views:AppDialogWindow x:Class="WearPartsControl.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:loc="clr-namespace:WearPartsControl.ApplicationServices.Localization"
        xmlns:views="clr-namespace:WearPartsControl.Views"
        mc:Ignorable="d"
        Title="{loc:Loc LoginWindowView.Title}"
        Height="540"
        Width="980"
        MinWidth="900"
        MinHeight="540"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WearPartsControl;component/Resources/ShellContentStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <ImageBrush x:Key="LoginWindowHeroImageBrush"
                        ImageSource="pack://application:,,,/WearPartsControl;component/Assets/loginwindow-background.png"
                        Stretch="UniformToFill" />
            <LinearGradientBrush x:Key="LoginWindowHeroOverlayBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#E0102E52" Offset="0" />
                <GradientStop Color="#CC12355E" Offset="0.48" />
                <GradientStop Color="#DE0A2240" Offset="1" />
            </LinearGradientBrush>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Rectangle Fill="{StaticResource LoginWindowHeroImageBrush}" />
            <Rectangle Fill="{StaticResource LoginWindowHeroOverlayBrush}"
                       Opacity="0.92" />
        <Grid Margin="28">
            <Border MaxWidth="980"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#14FFFFFF"
                    BorderBrush="#42FFFFFF"
                    BorderThickness="1"
                    CornerRadius="28">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.3*" />
                        <ColumnDefinition Width="420" />
                    </Grid.ColumnDefinitions>

                    <Border Padding="38 34"
                            Background="#22122A46"
                            CornerRadius="28,0,0,28">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Padding="18 12"
                                    HorizontalAlignment="Left"
                                    Background="#EEF5FB"
                                    BorderBrush="#55FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="18">
                                <Image Source="pack://application:,,,/WearPartsControl;component/Assets/catl.ico"
                                       Width="178"
                                       Stretch="Uniform" />
                            </Border>

                            <TextBlock Grid.Row="1"
                                       Margin="0 28 0 0"
                                       MaxWidth="380"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       TextWrapping="Wrap"
                                       Text="{loc:Loc LoginWindowView.HeroSubtitle}" />

                            <TextBlock Grid.Row="2"
                                       Margin="0 16 0 0"
                                       MaxWidth="420"
                                       VerticalAlignment="Top"
                                       FontSize="14"
                                       LineHeight="22"
                                       Foreground="#D8E7F4"
                                       TextWrapping="Wrap"
                                       Text="{loc:Loc LoginWindowView.HeroHint}" />

                            <Border Grid.Row="3"
                                    Margin="0 30 0 0"
                                    Padding="20 18"
                                    Background="#24FFFFFF"
                                    BorderBrush="#2DFFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Margin="0"
                                                   Style="{StaticResource ShellMetaLabelTextStyle}"
                                                   Foreground="#C8DDF0"
                                                   Text="{loc:Loc LoginWindowView.ResourceNumberLabel}" />
                                        <TextBlock Style="{StaticResource ShellMetaValueTextStyle}"
                                                   Foreground="White"
                                                   FontSize="18"
                                                   Text="{Binding ResourceNumber, Mode=OneWay}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Margin="0"
                                                   Style="{StaticResource ShellMetaLabelTextStyle}"
                                                   Foreground="#C8DDF0"
                                                   Text="{loc:Loc LoginWindowView.SiteLabel}" />
                                        <TextBlock Style="{StaticResource ShellMetaValueTextStyle}"
                                                   Foreground="White"
                                                   FontSize="18"
                                                   Text="{Binding SiteCode, Mode=OneWay}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Padding="34 32"
                            Background="#F8FBFF"
                            CornerRadius="0,28,28,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Foreground="#61758A"
                                       Text="{loc:Loc LoginWindowView.HeroSubtitle}" />
                            <TextBlock Grid.Row="1"
                                       Margin="0 12 0 0"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#1E3550"
                                       TextWrapping="Wrap"
                                       Text="{Binding LoginPrompt}" />
                            <TextBlock Grid.Row="2"
                                       Margin="0 12 0 0"
                                       Foreground="#61758A"
                                       LineHeight="21"
                                       TextWrapping="Wrap"
                                       Text="{Binding StatusMessage}" />

                            <PasswordBox x:Name="PasswordInputBox"
                                         Grid.Row="3"
                                         Height="46"
                                         Margin="0 28 0 0"
                                         Padding="14 0"
                                         VerticalContentAlignment="Center"
                                         PasswordChanged="PasswordInputBox_OnPasswordChanged"
                                         PreviewKeyDown="PasswordInputBox_OnPreviewKeyDown"
                                         PreviewTextInput="PasswordInputBox_OnPreviewTextInput"
                                         DataObject.Pasting="PasswordInputBox_OnPasting" />

                            <StackPanel Grid.Row="4"
                                        Margin="0 14 0 0"
                                        VerticalAlignment="Top">
                                <Button Height="44"
                                        Style="{StaticResource ButtonPrimary}"
                                        Command="{Binding LoginCommand}"
                                        Content="{loc:Loc LoginWindowView.LoginButton}" />
                                <TextBlock Margin="0 16 0 0"
                                           Foreground="#6A7E91"
                                           LineHeight="21"
                                           TextWrapping="Wrap"
                                           Text="{loc:Loc LoginWindowView.HeroHint}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
            <Border Background="#40FFFFFF"
                    Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                <hc:LoadingCircle Width="60"
                                  Height="60"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  IsRunning="{Binding IsBusy}" />
            </Border>
        </Grid>
    </Grid>
</views:AppDialogWindow>
