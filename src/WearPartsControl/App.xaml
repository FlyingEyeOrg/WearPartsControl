<Application x:Class="WearPartsControl.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WearPartsControl"
             xmlns:views="clr-namespace:WearPartsControl.Views"
             xmlns:hc="clr-namespace:HandyControl.Controls;assembly=HandyControl">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/SkinDefault.xaml" />
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Style TargetType="{x:Type Window}">
                <Setter Property="Icon" Value="pack://application:,,,/Assets/app.ico" />
            </Style>
            <Style TargetType="{x:Type views:AppDialogWindow}">
                <Setter Property="Icon" Value="pack://application:,,,/Assets/app.ico" />
                <Setter Property="ShowInTaskbar" Value="False" />
                <Setter Property="ResizeMode" Value="NoResize" />
                <Setter Property="WindowStartupLocation" Value="CenterOwner" />
                <Setter Property="WindowStyle" Value="SingleBorderWindow" />
                <Setter Property="Background" Value="Transparent" />
            </Style>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
